# ── DATABASE ──────────────────────────────────────────
# Development (SQLite local file):
DATABASE_URL=file:./masterstack.db

# Production (Turso - free tier):
# Get from: turso db show masterstack-db --url
# TURSO_DATABASE_URL=libsql://masterstack-db-<username>.turso.io
# TURSO_AUTH_TOKEN=<token from: turso db tokens create masterstack-db>

# ── AUTH ──────────────────────────────────────────────
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=change_this_to_a_random_64_char_secret_in_production
JWT_EXPIRES_IN=30d

# ── SERVER ─────────────────────────────────────────────
PORT=3001
NODE_ENV=development

# ── CORS ───────────────────────────────────────────────
# Comma-separated list of allowed origins
# For dev: file:// (HTML opened from filesystem) and localhost
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:5500,http://localhost:5500
